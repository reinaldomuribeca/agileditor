# ─────────────────────────────────────────────────────────────────
# Ágil Editor — environment configuration
# Copy this file to `.env.local` and fill in. Never commit `.env.local`.
# ─────────────────────────────────────────────────────────────────

# ── REQUIRED — AI providers ─────────────────────────────────────

# OpenAI: used for image generation (gpt-image-1) AND as Whisper fallback if GROQ_API_KEY is empty.
OPENAI_API_KEY=sk-...

# Anthropic: used by Claude Sonnet for scene analysis. No fallback.
ANTHROPIC_API_KEY=sk-ant-...

# ── OPTIONAL — Whisper provider override ────────────────────────

# Groq: free Whisper-large-v3. If set, used instead of OpenAI Whisper.
# Sign up at https://console.groq.com — leave empty to use OpenAI.
GROQ_API_KEY=

# ── REQUIRED IN PRODUCTION — public URL ─────────────────────────

# The URL the browser uses to reach this app. Remotion's headless Chromium
# uses this to fetch the source video and PNGs during render.
# Local dev: http://localhost:3333
# Production: https://your-domain.com (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3333

# ── OPTIONAL — server bindings ──────────────────────────────────

# Port the Next.js server listens on. Default 3333.
PORT=3333

# Host the server binds to. 0.0.0.0 (default in start script) makes it reachable
# from outside the container/VPS. Use 127.0.0.1 if you proxy through nginx/caddy
# on the same machine and don't want the port exposed publicly.
HOST=0.0.0.0

# ── REQUIRED IN PRODUCTION — persistent storage ─────────────────

# Where job artifacts live (raw.mp4, normalized.mp4, cut.mp4, output.mp4, images/, metadata.json).
# IMPORTANT: must be a persistent volume in production (NOT /tmp).
# Local dev default: ./data/jobs (repo-relative, gitignored).
# Docker: /app/data/jobs (mount a volume).
# VPS bare-metal: /var/agil-editor/jobs (with chown to the runtime user).
JOBS_DIR=./data/jobs

# ── OPTIONAL — security & limits ────────────────────────────────

# Single-password auth (added in Phase B). When set, all routes except /api/health
# require a valid session cookie. Leave empty in dev to disable.
APP_PASSWORD=

# Maximum upload size in megabytes. Enforced server-side in /api/upload.
MAX_VIDEO_SIZE_MB=200

# Maximum source video duration in seconds. Whisper has a 24MB audio cap, which
# at 64 kbps mono is roughly 50 minutes; default 600s (10 min) keeps Claude tokens
# bounded too.
MAX_VIDEO_DURATION_SECONDS=600
